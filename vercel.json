{
  "version": 2,
  "buildCommand": "cd coddk-main && npm install && npm run build",
  "outputDirectory": "coddk-main/dist",
  "installCommand": "npm --prefix coddk-backend install && npm --prefix coddk-main install",
  "functions": {
    "coddk-backend/server.js": {
      "runtime": "nodejs22.x",
      "includeFiles": "coddk-backend/**"
    }
  },
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/coddk-backend/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
